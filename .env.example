# Resend - Email delivery
# Get your API key from https://resend.com
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"

# Contact form recipient (REQUIRED for the contact form to work)
CONTACT_TO_EMAIL="ahmedyhussain07@gmail.com"

# Optional: GitHub personal access token raises the unauthenticated API rate limit.
# The GitHub project page works without it (60 req/hr unauthenticated).
# Create one at https://github.com/settings/tokens (no scopes needed for public repos).
# GITHUB_TOKEN="ghp_xxxxxxxxxxxxxxxxxxxx"

# Contact form sender - must match a domain verified in your Resend dashboard
# https://resend.com/domains  (verify ahmedyhussain.com)
# Default: Ahmed Hussain <noreply@ahmedyhussain.com>
CONTACT_FROM_EMAIL="Ahmed Hussain <noreply@ahmedyhussain.com>"

# Upstash Redis (ninja leaderboard) - injected by the Vercel Marketplace integration
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Base URL — used for OG images and canonical URLs
# Default: https://ahmedyhussain.com
NEXT_PUBLIC_BASE_URL="https://ahmedyhussain.com"
