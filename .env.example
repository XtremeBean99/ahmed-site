# Database — Neon PostgreSQL
# Get your connection string from https://neon.tech
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Resend — Email delivery
# Get your API key from https://resend.com
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"

# Contact form recipient (defaults to ahmedyhussain07@gmail.com if not set)
CONTACT_TO_EMAIL="ahmedyhussain07@gmail.com"

# Contact form sender — must match a domain verified in your Resend dashboard
# https://resend.com/domains — add ahmedyhussain.com and verify DNS records
# Default: Ahmed Hussain <noreply@ahmedyhussain.com>
CONTACT_FROM_EMAIL="Ahmed Hussain <noreply@ahmedyhussain.com>"

# Rate limiting — add a random secret to prevent IP hash rainbow-table attacks
# Generate one with: openssl rand -hex 32
RATE_LIMIT_SALT="your-random-secret-here"
